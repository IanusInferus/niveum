#Template BinaryTranslator_Alias a:AliasDef NamespaceName:String
    ${BinaryTranslator_Alias(a.GetTypeSpec().SimpleName(NamespaceName), GetTypeString(a.GetTypeSpec(), NamespaceName), a.Type, NamespaceName)}

#Template BinaryTranslator_Alias Name:String TypeString:String ValueType:TypeSpec NamespaceName:String
    $$
        var ValueSimpleName = ValueType.SimpleName(NamespaceName);
    pub fn [[${Name}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let v = Self::[[${ValueSimpleName}_from_binary]](s)?;
        Ok(${TypeString}(v))
    }
    pub fn [[${Name}_to_binary]](s: &mut dyn WritableStream, o: &${TypeString}) -> Result<(), BinaryError> {
        Self::[[${ValueSimpleName}_to_binary]](s, &o.0)
    }

#Template BinaryTranslator_Record r:RecordDef NamespaceName:String
    ${BinaryTranslator_Record(r.GetTypeSpec().SimpleName(NamespaceName), GetTypeString(r.GetTypeSpec(), NamespaceName), r.Fields, NamespaceName)}

#Template BinaryTranslator_Record Name:String TypeString:String Fields:List<VariableDef> NamespaceName:String
    pub fn [[${Name}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        Ok(${TypeString} {
            $$
                foreach (var f in Fields)
                {
                    ##
                        [[${f.Name}]]: Self::[[${f.Type.SimpleName(NamespaceName)}_from_binary]](s)?,
                }
        })
    }
    pub fn [[${Name}_to_binary]](s: &mut dyn WritableStream, o: &${TypeString}) -> Result<(), BinaryError> {
        $$
            foreach (var f in Fields)
            {
                ##
                    Self::[[${f.Type.SimpleName(NamespaceName)}_to_binary]](s, &o.[[${f.Name}]])?;
            }
        Ok(())
    }

#Template BinaryTranslator_TaggedUnion tu:TaggedUnionDef NamespaceName:String
    ${BinaryTranslator_TaggedUnion(tu.GetTypeSpec().SimpleName(NamespaceName), GetTypeString(tu.GetTypeSpec(), NamespaceName), tu.Alternatives, NamespaceName, tu.VersionedName())}

#Template BinaryTranslator_TaggedUnion Name:String TypeString:String Alternatives:List<VariableDef> NamespaceName:String EnclosingVersionedName:String
    pub fn [[${Name}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let tag = Self::Int_from_binary(s)?;
        match tag {
            $$
                {
                    var k = 0;
                    foreach (var a in Alternatives)
                    {
                        if (a.Type.OnTypeRef && a.Type.TypeRef.NameMatches("Unit"))
                        {
                            ##
                                ${k} => Ok(${TypeString}::[[${a.Name}]])
                        }
                        else
                        {
                            ##
                                ${k} => {
                                    let v = Self::[[${a.Type.SimpleName(NamespaceName)}_from_binary]](s)?;
                                    Ok(${TypeString}::[[${a.Name}]](${WrapVariant("v", a.Type, EnclosingVersionedName, NamespaceName)}))
                                }
                        }
                        k += 1;
                    }
                }
            _ => Err(binary_error("InvalidOperation"))
        }
    }
    pub fn [[${Name}_to_binary]](s: &mut dyn WritableStream, o: &${TypeString}) -> Result<(), BinaryError> {
        match o {
            $$
                {
                    var k = 0;
                    foreach (var a in Alternatives)
                    {
                        if (a.Type.OnTypeRef && a.Type.TypeRef.NameMatches("Unit"))
                        {
                            ##
                                ${TypeString}::[[${a.Name}]] => {
                                    Self::Int_to_binary(s, &${k})?;
                                    Ok(())
                                }
                        }
                        else
                        {
                            ##
                                ${TypeString}::[[${a.Name}]](v) => {
                                    Self::Int_to_binary(s, &${k})?;
                                    Self::[[${a.Type.SimpleName(NamespaceName)}_to_binary]](s, ${DerefVariant("v", a.Type, EnclosingVersionedName, NamespaceName)})?;
                                    Ok(())
                                }
                        }
                        k += 1;
                    }
                }
        }
    }
#Template BinaryTranslator_Enum e:EnumDef NamespaceName:String
    ${BinaryTranslator_Enum(e.GetTypeSpec().SimpleName(NamespaceName), GetTypeString(e.GetTypeSpec(), NamespaceName), e.UnderlyingType.SimpleName(NamespaceName), GetTypeString(e.UnderlyingType, NamespaceName), NamespaceName)}

#Template BinaryTranslator_Enum Name:String TypeString:String UnderlyingSimpleName:String UnderlyingType:String NamespaceName:String
    pub fn [[${Name}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let v = Self::[[${UnderlyingSimpleName}_from_binary]](s)?;
        Ok(unsafe { std::mem::transmute::<${UnderlyingType}, ${TypeString}>(v) })
    }
    pub fn [[${Name}_to_binary]](s: &mut dyn WritableStream, o: &${TypeString}) -> Result<(), BinaryError> {
        let v: ${UnderlyingType} = unsafe { std::mem::transmute::<${TypeString}, ${UnderlyingType}>(*o) };
        Self::[[${UnderlyingSimpleName}_to_binary]](s, &v)
    }

#Template BinaryTranslator_Tuple tp:TypeSpec NamespaceName:String
    $$
        var SimpleName = tp.SimpleName(NamespaceName);
        var TypeString = GetTypeString(tp, NamespaceName);
    pub fn [[${SimpleName}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        $$
            var ItemNames = new List<String>{};
            {
                int k = 0;
                foreach (var t in tp.Tuple) {
                    ##
                        let item${k} = Self::[[${t.SimpleName(NamespaceName)}_from_binary]](s)?;
                    ItemNames.Add("item" + (k).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    k += 1;
                }
            }
        Ok((${String.Join(", ", ItemNames)}))
    }
    pub fn [[${SimpleName}_to_binary]](s: &mut dyn WritableStream, t: &${TypeString}) -> Result<(), BinaryError> {
        $$
            {
                int k = 0;
                foreach (var t in tp.Tuple) {
                    ##
                        Self::[[${t.SimpleName(NamespaceName)}_to_binary]](s, &t.${k})?;
                    k += 1;
                }
            }
        Ok(())
    }

#Template BinaryTranslator_Optional o:TypeSpec NamespaceName:String
    $$
        var ElementType = o.GenericTypeSpec.ParameterValues.Single();
        var SimpleName = o.SimpleName(NamespaceName);
        var TypeString = GetTypeString(o, NamespaceName);
    pub fn [[${SimpleName}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let tag = Self::Int_from_binary(s)?;
        if tag == 0 {
            Ok(None)
        } else {
            Ok(Some(Self::[[${ElementType.SimpleName(NamespaceName)}_from_binary]](s)?))
        }
    }
    pub fn [[${SimpleName}_to_binary]](s: &mut dyn WritableStream, o: &${TypeString}) -> Result<(), BinaryError> {
        match o
        {
            None => {
                Self::Int_to_binary(s, &0)?;
            }
            Some(v) => {
                Self::Int_to_binary(s, &1)?;
                Self::[[${ElementType.SimpleName(NamespaceName)}_to_binary]](s, &*v)?;
            }
        }
        Ok(())
    }

#Template BinaryTranslator_List l:TypeSpec NamespaceName:String
    $$
        var SimpleName = l.SimpleName(NamespaceName);
        var TypeString = GetTypeString(l, NamespaceName);
        var ElementType = l.GenericTypeSpec.ParameterValues.Single();
        var ElementSimpleName = ElementType.SimpleName(NamespaceName);
    pub fn [[${SimpleName}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let length: usize = s.read_size()?.try_into().map_err(|_| binary_error("conversion overflow"))?;
        $$
            if (ElementType.OnTypeRef && ElementType.TypeRef.NameMatches("Byte", "UInt8")) {
                ##
                    s.read_bytes(length)
            }
            else
            {
                ##
                    let mut l = ${GetGenericNew(TypeString)};
                    for _ in 0..length
                    {
                        l.push(Self::[[${ElementSimpleName}_from_binary]](s)?);
                    }
                    Ok(l)
            }
    }
    pub fn [[${SimpleName}_to_binary]](s: &mut dyn WritableStream, l: &${TypeString}) -> Result<(), BinaryError> {
        s.write_size(l.len().try_into().map_err(|_| binary_error("conversion overflow"))?)?;
        $$
            if (ElementType.OnTypeRef && ElementType.TypeRef.NameMatches("Byte", "UInt8")) {
                ##
                    s.write_bytes(l)?;
            }
            else
            {
                ##
                    for e in l.iter() {
                        Self::[[${ElementSimpleName}_to_binary]](s, e)?;
                    }
            }
        Ok(())
    }

#Template BinaryTranslator_Set l:TypeSpec NamespaceName:String
    $$
        var SimpleName = l.SimpleName(NamespaceName);
        var TypeString = GetTypeString(l, NamespaceName);
        var ElementSimpleName = l.GenericTypeSpec.ParameterValues.Single().SimpleName(NamespaceName);
    pub fn [[${SimpleName}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let length: usize = s.read_size()?.try_into().map_err(|_| binary_error("conversion overflow"))?;
        let mut l = ${GetGenericNew(TypeString)};
        for _ in 0..length
        {
            l.insert(Self::[[${ElementSimpleName}_from_binary]](s)?);
        }
        Ok(l)
    }
    pub fn [[${SimpleName}_to_binary]](s: &mut dyn WritableStream, l: &${TypeString}) -> Result<(), BinaryError> {
        s.write_size(l.len().try_into().map_err(|_| binary_error("conversion overflow"))?)?;
        for e in l.iter() {
            Self::[[${ElementSimpleName}_to_binary]](s, e)?;
        }
        Ok(())
    }

#Template BinaryTranslator_Map l:TypeSpec NamespaceName:String
    $$
        var gp = l.GenericTypeSpec.ParameterValues;
        if (gp.Count != 2) {
            throw new ArgumentException();
        }
        var SimpleName = l.SimpleName(NamespaceName);
        var TypeString = GetTypeString(l, NamespaceName);
        var KeySimpleName = gp[0].SimpleName(NamespaceName);
        var ValueSimpleName = gp[1].SimpleName(NamespaceName);
    pub fn [[${SimpleName}_from_binary]](s: &mut dyn ReadableStream) -> Result<${TypeString}, BinaryError> {
        let length: usize = s.read_size()?.try_into().map_err(|_| binary_error("conversion overflow"))?;
        let mut l = ${GetGenericNew(TypeString)};
        for _ in 0..length
        {
            let key = Self::[[${KeySimpleName}_from_binary]](s)?;
            let value = Self::[[${ValueSimpleName}_from_binary]](s)?;
            l.insert(key, value);
        }
        Ok(l)
    }
    pub fn [[${SimpleName}_to_binary]](s: &mut dyn WritableStream, l: &${TypeString}) -> Result<(), BinaryError> {
        s.write_size(l.len().try_into().map_err(|_| binary_error("conversion overflow"))?)?;
        for (key, value) in l.iter() {
            Self::[[${KeySimpleName}_to_binary]](s, key)?;
            Self::[[${ValueSimpleName}_to_binary]](s, value)?;
        }
        Ok(())
    }

