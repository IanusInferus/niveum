#Template Streams
    pub type BinaryError = anyhow::Error;

    #[inline]
    pub fn binary_error(msg: impl std::fmt::Display) -> BinaryError {
        anyhow!("{msg}")
    }

    pub trait ReadableStream {
        fn read_byte(&mut self) -> Result<u8, BinaryError>;
        fn read_bytes(&mut self, size: usize) -> Result<Vec<u8>, BinaryError>;

        fn read_unit(&mut self) -> Result<(), BinaryError> {
            Ok(())
        }
        fn read_boolean(&mut self) -> Result<bool, BinaryError> {
            Ok(self.read_byte()? != 0)
        }

        fn read_u8(&mut self) -> Result<u8, BinaryError> {
            self.read_byte()
        }
        fn read_u16(&mut self) -> Result<u16, BinaryError> {
            let b0 = self.read_byte()? as u16;
            let b1 = self.read_byte()? as u16;
            Ok(b0 | (b1 << 8))
        }
        fn read_u32(&mut self) -> Result<u32, BinaryError> {
            let b0 = self.read_byte()? as u32;
            let b1 = self.read_byte()? as u32;
            let b2 = self.read_byte()? as u32;
            let b3 = self.read_byte()? as u32;
            Ok(b0 | (b1 << 8) | (b2 << 16) | (b3 << 24))
        }
        fn read_u64(&mut self) -> Result<u64, BinaryError> {
            let b0 = self.read_byte()? as u64;
            let b1 = self.read_byte()? as u64;
            let b2 = self.read_byte()? as u64;
            let b3 = self.read_byte()? as u64;
            let b4 = self.read_byte()? as u64;
            let b5 = self.read_byte()? as u64;
            let b6 = self.read_byte()? as u64;
            let b7 = self.read_byte()? as u64;
            Ok(b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56))
        }

        fn read_i8(&mut self) -> Result<i8, BinaryError> {
            Ok(self.read_byte()? as i8)
        }
        fn read_i16(&mut self) -> Result<i16, BinaryError> {
            Ok(self.read_u16()? as i16)
        }
        fn read_i32(&mut self) -> Result<i32, BinaryError> {
            Ok(self.read_u32()? as i32)
        }
        fn read_i64(&mut self) -> Result<i64, BinaryError> {
            Ok(self.read_u64()? as i64)
        }

        fn read_f32(&mut self) -> Result<f32, BinaryError> {
            let i = self.read_i32()?;
            Ok(f32::from_bits(i as u32))
        }
        fn read_f64(&mut self) -> Result<f64, BinaryError> {
            let i = self.read_i64()?;
            Ok(f64::from_bits(i as u64))
        }

        fn read_size(&mut self) -> Result<i64, BinaryError> {
            let lower = self.read_u32()?;
            if (lower & 0x80000000) == 0 {
                return Ok(lower as i64);
            }
            let upper = self.read_u32()?;
            if (upper & 0x80000000) != 0 {
                return Err(binary_error("out_of_range"));
            }
            Ok(((upper as i64) << 31) | (lower as i64))
        }

        fn read_string(&mut self) -> Result<String, BinaryError> {
            let length: usize = self.read_size()?.try_into().map_err(|_| binary_error("conversion overflow"))?;
            let n = length / 2;
            let mut v = String::with_capacity(n);
            for _ in 0..n {
                let c = self.read_u16()?;
                v.push(char::from_u32(c as u32).unwrap_or('\u{FFFD}'));
            }
            Ok(v)
        }
    }

    pub trait WritableStream {
        fn write_byte(&mut self, b: u8) -> Result<(), BinaryError>;
        fn write_bytes(&mut self, l: &[u8]) -> Result<(), BinaryError>;

        fn write_unit(&mut self, _v: ()) -> Result<(), BinaryError> {
            Ok(())
        }
        fn write_boolean(&mut self, v: bool) -> Result<(), BinaryError> {
            if v { self.write_byte(0xFF) } else { self.write_byte(0) }
        }

        fn write_u8(&mut self, v: u8) -> Result<(), BinaryError> {
            self.write_byte(v)
        }
        fn write_u16(&mut self, v: u16) -> Result<(), BinaryError> {
            self.write_byte((v & 0xFF) as u8)?;
            self.write_byte(((v >> 8) & 0xFF) as u8)
        }
        fn write_u32(&mut self, v: u32) -> Result<(), BinaryError> {
            self.write_byte((v & 0xFF) as u8)?;
            self.write_byte(((v >> 8) & 0xFF) as u8)?;
            self.write_byte(((v >> 16) & 0xFF) as u8)?;
            self.write_byte(((v >> 24) & 0xFF) as u8)
        }
        fn write_u64(&mut self, v: u64) -> Result<(), BinaryError> {
            self.write_byte((v & 0xFF) as u8)?;
            self.write_byte(((v >> 8) & 0xFF) as u8)?;
            self.write_byte(((v >> 16) & 0xFF) as u8)?;
            self.write_byte(((v >> 24) & 0xFF) as u8)?;
            self.write_byte(((v >> 32) & 0xFF) as u8)?;
            self.write_byte(((v >> 40) & 0xFF) as u8)?;
            self.write_byte(((v >> 48) & 0xFF) as u8)?;
            self.write_byte(((v >> 56) & 0xFF) as u8)
        }

        fn write_i8(&mut self, v: i8) -> Result<(), BinaryError> {
            self.write_byte(v as u8)
        }
        fn write_i16(&mut self, v: i16) -> Result<(), BinaryError> {
            self.write_u16(v as u16)
        }
        fn write_i32(&mut self, v: i32) -> Result<(), BinaryError> {
            self.write_u32(v as u32)
        }
        fn write_i64(&mut self, v: i64) -> Result<(), BinaryError> {
            self.write_u64(v as u64)
        }

        fn write_f32(&mut self, v: f32) -> Result<(), BinaryError> {
            self.write_i32(v.to_bits() as i32)
        }
        fn write_f64(&mut self, v: f64) -> Result<(), BinaryError> {
            self.write_i64(v.to_bits() as i64)
        }

        fn write_size(&mut self, v: i64) -> Result<(), BinaryError> {
            if (v < 0) || (v > 0x3FFFFFFFFFFFFFFF) {
                return Err(binary_error("out_of_range"));
            }
            let lower = ((v as u64) & 0x7FFFFFFF) as u32;
            let upper = (((v as u64) >> 31) & 0x7FFFFFFF) as u32;
            if upper != 0 {
                self.write_u32(lower | 0x80000000)?;
                self.write_u32(upper)
            }
            else {
                self.write_u32(lower)
            }
        }

        fn write_string(&mut self, v: &str) -> Result<(), BinaryError> {
            self.write_size((v.chars().count() * 2).try_into().map_err(|_| binary_error("conversion overflow"))?)?;
            for c in v.chars() {
                self.write_u16(c as u16)?;
            }
            Ok(())
        }
    }

    pub struct ByteArrayStream {
        buffer: Vec<u8>,
        position: usize,
    }

    impl ByteArrayStream {
        pub fn new() -> Self {
            ByteArrayStream { buffer: Vec::new(), position: 0 }
        }

        pub fn get_position(&self) -> usize {
            self.position
        }

        pub fn set_position(&mut self, position: usize) {
            self.position = position;
        }

        pub fn get_length(&self) -> usize {
            self.buffer.len()
        }

        pub fn set_length(&mut self, length: usize) {
            self.buffer.resize(length, 0);
        }

        pub fn into_vec(self) -> Vec<u8> {
            self.buffer
        }
    }

    impl ReadableStream for ByteArrayStream {
        fn read_byte(&mut self) -> Result<u8, BinaryError> {
            if self.position + 1 > self.buffer.len() {
                return Err(binary_error("out_of_range"));
            }
            let b = self.buffer[self.position];
            self.position += 1;
            Ok(b)
        }

        fn read_bytes(&mut self, size: usize) -> Result<Vec<u8>, BinaryError> {
            if self.position + size > self.buffer.len() {
                return Err(binary_error("out_of_range"));
            }
            let l = self.buffer[self.position..self.position + size].to_vec();
            self.position += size;
            Ok(l)
        }
    }

    impl WritableStream for ByteArrayStream {
        fn write_byte(&mut self, b: u8) -> Result<(), BinaryError> {
            if self.position + 1 > self.buffer.len() {
                self.buffer.resize(self.position + 1, 0);
            }
            self.buffer[self.position] = b;
            self.position += 1;
            Ok(())
        }

        fn write_bytes(&mut self, l: &[u8]) -> Result<(), BinaryError> {
            let size = l.len();
            if size == 0 { return Ok(()); }
            if self.position + size > self.buffer.len() {
                self.buffer.resize(self.position + size, 0);
            }
            self.buffer[self.position..self.position + size].copy_from_slice(l);
            self.position += size;
            Ok(())
        }
    }

#Template BinaryTranslator Schema:Schema NamespaceName:String
    /// Binary serialization translator
    /// All functions use little-endian encoding compatible with Niveum binary protocol
    pub struct BinaryTranslator;

    impl BinaryTranslator {
        ${GetBinaryTranslatorSerializers(Schema, NamespaceName)}
    }

#Template BinaryTranslator_Primitive_Unit
    pub fn Unit_from_binary(s: &mut dyn ReadableStream) -> Result<(), BinaryError> {
        s.read_unit()?;
        Ok(())
    }
    pub fn Unit_to_binary(s: &mut dyn WritableStream, _v: &()) -> Result<(), BinaryError> {
        s.write_unit(())
    }

