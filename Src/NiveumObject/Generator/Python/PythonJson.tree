#Template JsonTranslator_Record Name:String TypeString:String Fields:List<VariableDef> NamespaceName:String
    @staticmethod
    def [[${Name}FromJson]](j: Any) -> ${TypeString}:
        if not isinstance(j, dict):
            raise TypeError('Expected object')
        return ${TypeString}(
            $$
                int k = 0;
                foreach (var f in Fields)
                {
                    if (k == Fields.Count - 1)
                    {
                        ##
                            [[${f.Name}]] = JsonTranslator.[[${f.Type.SimpleName(NamespaceName)}FromJson]](j[${GetEscapedStringLiteral(LowercaseCamelize(f.Name))}])
                    }
                    else
                    {
                        ##
                            [[${f.Name}]] = JsonTranslator.[[${f.Type.SimpleName(NamespaceName)}FromJson]](j[${GetEscapedStringLiteral(LowercaseCamelize(f.Name))}]),
                    }
                    k += 1;
                }
        )

    @staticmethod
    def [[${Name}ToJson]](o: ${TypeString}) -> Any:
        return {
            $$
                for (int i = 0; i < Fields.Count; i++)
                {
                    var a = Fields[i];
                    ##
                        ${GetEscapedStringLiteral(LowercaseCamelize(a.Name))}: JsonTranslator.[[${a.Type.SimpleName(NamespaceName)}ToJson]](o.[[${a.Name}]]),
                }
        }

#Template JsonTranslator_TaggedUnion tu:TaggedUnionDef NamespaceName:String
    ${JsonTranslator_TaggedUnion(tu.GetTypeSpec().SimpleName(NamespaceName), GetTypeString(tu.GetTypeSpec(), NamespaceName), GetSuffixedTypeName(tu.Name, tu.Version, "Tag", NamespaceName), GetSuffixedTypeString(tu.Name, tu.Version, "Tag", NamespaceName), tu.Alternatives, NamespaceName)}

#Template JsonTranslator_TaggedUnion Name:String TypeString:String TagName:String TagTypeString:String Alternatives:List<VariableDef> NamespaceName:String
    @staticmethod
    def [[${Name}FromJson]](j: Any) -> ${TypeString}:
        if not isinstance(j, dict):
            raise TypeError('Expected object')
        $$
            foreach (var a in Alternatives)
            {
                ##
                    if ${GetEscapedStringLiteral(LowercaseCamelize(a.Name))} in j:
                        $$
                            if (a.Type.OnTypeRef && a.Type.TypeRef.NameMatches("Unit"))
                            {
                                ##
                                    return ${TypeString}.Create[[${a.Name}]]()
                            }
                            else
                            {
                                ##
                                    return ${TypeString}.Create[[${a.Name}]](JsonTranslator.[[${a.Type.SimpleName(NamespaceName)}FromJson]](j[${GetEscapedStringLiteral(LowercaseCamelize(a.Name))}]))
                            }
            }
        raise TypeError('Unknown tag')

    @staticmethod
    def [[${Name}ToJson]](o: ${TypeString}) -> Any:
        $$
            foreach (var a in Alternatives)
            {
                ##
                    if o.Tag_ == ${TagName}.[[${a.Name}]]:
                        $$
                            if (a.Type.OnTypeRef && a.Type.TypeRef.NameMatches("Unit"))
                            {
                                ##
                                    return {${GetEscapedStringLiteral(LowercaseCamelize(a.Name))}: {}}
                            }
                            else
                            {
                                ##
                                    return {${GetEscapedStringLiteral(LowercaseCamelize(a.Name))}: JsonTranslator.[[${a.Type.SimpleName(NamespaceName)}ToJson]](o.[[${a.Name}]]())}
                            }
            }
        raise TypeError('Unknown tag')

