#Template JsonTranslator_Tuple tp:TypeSpec NamespaceName:String
    $$
        var SimpleName = tp.SimpleName(NamespaceName);
        var TypeString = GetTypeString(tp, NamespaceName);
    @staticmethod
    def [[${SimpleName}FromJson]](j: Any) -> ${TypeString}:
        if not isinstance(j, list):
            raise TypeError('Expected array')
        return [
            $$
                {
                    int k = 0;
                    foreach (var t in tp.Tuple)
                    {
                        if (k == tp.Tuple.Count - 1)
                        {
                            ##
                                JsonTranslator.[[${t.SimpleName(NamespaceName)}FromJson]](j[${k}])
                        }
                        else
                        {
                            ##
                                JsonTranslator.[[${t.SimpleName(NamespaceName)}FromJson]](j[${k}]),
                        }
                        k += 1;
                    }
                }
        ]

    @staticmethod
    def [[${SimpleName}ToJson]](t: ${TypeString}) -> Any:
        return [
            $$
                {
                    int k = 0;
                    foreach (var t in tp.Tuple)
                    {
                        if (k == tp.Tuple.Count - 1)
                        {
                            ##
                                JsonTranslator.[[${t.SimpleName(NamespaceName)}ToJson]](t[${k}])
                        }
                        else
                        {
                            ##
                                JsonTranslator.[[${t.SimpleName(NamespaceName)}ToJson]](t[${k}]),
                        }
                        k += 1;
                    }
                }
        ]

#Template JsonTranslator_Optional o:TypeSpec GenericOptionalType:TaggedUnionDef NamespaceName:String
    $$
        var ElementType = o.GenericTypeSpec.ParameterValues.Single();
        var SimpleName = o.SimpleName(NamespaceName);
        var TypeString = GetTypeString(o, NamespaceName);
        var ElementSimpleName = ElementType.SimpleName(NamespaceName);
    @staticmethod
    def [[${SimpleName}FromJson]](j: Any) -> ${TypeString}:
        if not isinstance(j, dict):
            raise TypeError('Expected object')
        if "none" in j:
            return None
        return JsonTranslator.[[${ElementSimpleName}FromJson]](j["some"])

    @staticmethod
    def [[${SimpleName}ToJson]](o: ${TypeString}) -> Any:
        if o is None:
            return {"none": {}}
        return {"some": JsonTranslator.[[${ElementSimpleName}ToJson]](o)}

#Template JsonTranslator_List l:TypeSpec NamespaceName:String
    $$
        var SimpleName = l.SimpleName(NamespaceName);
