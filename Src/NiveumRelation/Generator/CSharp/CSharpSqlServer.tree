#Template Lock_LockingStatement EntityNameAndParameterAndValues:String
    if (TransactionLock != null) { TransactionLock.Enter(new Object[] { ${EntityNameAndParameterAndValues} }); }

#Template SelectLockDelete_ParameterAdd ParameterName:String
    Add(cmd, "${ParameterName}", [[${ParameterName}]]);

#Template InsertUpdateUpsert_ParameterAdd ParameterName:String
    Add(cmd, "${ParameterName}", v.[[${ParameterName}]]);

#Template SelectLock_ResultSet ParameterName:String TypeGet:String
