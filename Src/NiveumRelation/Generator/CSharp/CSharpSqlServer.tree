    ${ParameterAdds}
    cmd.ExecuteNonQuery();

#Template InsertUpdateUpsert_One SQL:String ParameterAdds:IEnumerable<String>
    var cmd = CreateTextCommand();
    cmd.CommandText = @"${SQL}";
    ${ParameterAdds}
    if (cmd.ExecuteNonQuery() != 1)
    {
        throw new InvalidOperationException();
    }

