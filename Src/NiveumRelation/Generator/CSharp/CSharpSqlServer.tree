#Template DataAccessBase
    public partial class SqlServerDataAccess : IDataAccess
    {
        private SqlConnection Connection;
        private SqlTransaction Transaction;
        private ITransactionLock TransactionLock;
        public SqlServerDataAccess(String ConnectionString, IsolationLevel IsolationLevel, ITransactionLock TransactionLock)
        {
            Connection = new SqlConnection(ConnectionString);
            Connection.Open();
            Transaction = Connection.BeginTransaction(IsolationLevel);
            this.TransactionLock = TransactionLock;
        }
        public SqlServerDataAccess(String ConnectionString, IsolationLevel IsolationLevel, Func<SqlConnection, SqlTransaction, ITransactionLock> TransactionLockFactory)
        {
            Connection = new SqlConnection(ConnectionString);
            Connection.Open();
            Transaction = Connection.BeginTransaction(IsolationLevel);
            this.TransactionLock = TransactionLockFactory(Connection, Transaction);
        }

        public void Dispose()
        {
            if (Transaction != null)
            {
                Transaction.Rollback();
                Transaction.Dispose();
                Transaction = null;
            }
            if (TransactionLock != null)
            {
                TransactionLock.ExitAll();
                TransactionLock = null;
            }
            if (Connection != null)
            {
                Connection.Dispose();
                Connection = null;
            }
        }

        public void Complete()
        {
            if (Transaction != null)
            {
                Transaction.Commit();
                Transaction.Dispose();
                Transaction = null;
            }
            else
            {
                throw new InvalidOperationException();
            }
            if (TransactionLock != null)
            {
                TransactionLock.ExitAll();
                TransactionLock = null;
            }
            if (Connection != null)
            {
                Connection.Dispose();
                Connection = null;
            }
            else
            {
                throw new InvalidOperationException();
            }
        }

        private SqlCommand CreateTextCommand()
        {
            var cmd = Connection.CreateCommand();
            cmd.Transaction = Transaction;
            cmd.CommandType = CommandType.Text;
            return cmd;
        }

        private static void Add(SqlCommand cmd, String ParameterName, Boolean Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Boolean;
            p.Value = Value;
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, String Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.String;
            p.Value = Value;
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Int Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Int32;
            p.Value = Value;
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Int64 Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Int64;
            p.Value = Value;
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Real Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Single;
            p.Value = (Single)(Value);
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, List<Byte> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Binary;
            p.Value = Value.ToArray();
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<Boolean> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Boolean;
            if (Value.OnSome)
            {
                p.Value = Value.Value;
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<String> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.String;
            if (Value.OnSome)
            {
                p.Value = Value.Value;
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<Int> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Int32;
            if (Value.OnSome)
            {
                p.Value = Value.Value;
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<Int64> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Int64;
            if (Value.OnSome)
            {
                p.Value = Value.Value;
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<Real> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Single;
            if (Value.OnSome)
            {
                p.Value = (Single)(Value.Value);
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static void Add(SqlCommand cmd, String ParameterName, Optional<List<Byte>> Value)
        {
            var p = cmd.CreateParameter();
            p.ParameterName = ParameterName;
            p.DbType = DbType.Binary;
            if (Value.OnSome)
            {
                p.Value = Value.Value.ToArray();
            }
            else
            {
                p.Value = DBNull.Value;
            }
            cmd.Parameters.Add(p);
        }
        private static Boolean GetBoolean(SqlDataReader dr, String FieldName)
        {
            return dr.GetBoolean(dr.GetOrdinal(FieldName));
        }
        private static String GetString(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlString(dr.GetOrdinal(FieldName));
            if (v.IsNull) { throw new InvalidOperationException(); }
            return v.Value;
        }
        private static Int GetInt(SqlDataReader dr, String FieldName)
        {
            return dr.GetInt32(dr.GetOrdinal(FieldName));
        }
        private static Int64 GetInt64(SqlDataReader dr, String FieldName)
        {
            return dr.GetInt64(dr.GetOrdinal(FieldName));
        }
        private static Double GetReal(SqlDataReader dr, String FieldName)
        {
            return dr.GetFloat(dr.GetOrdinal(FieldName));
        }
        private static List<Byte> GetBinary(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlBinary(dr.GetOrdinal(FieldName));
            if (v.IsNull) { throw new InvalidOperationException(); }
            return new List<Byte>(v.Value);
        }
        private static Optional<Boolean> GetOptionalOfBoolean(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlBoolean(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<Boolean>.Empty; }
            return v.Value;
        }
        private static Optional<String> GetOptionalOfString(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlString(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<String>.Empty; }
            return v.Value;
        }
        private static Optional<Int> GetOptionalOfInt(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlInt32(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<Int>.Empty; }
            return v.Value;
        }
        private static Optional<Int64> GetOptionalOfInt64(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlInt64(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<Int64>.Empty; }
            return v.Value;
        }
        private static Optional<Real> GetOptionalOfReal(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlSingle(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<Real>.Empty; }
            return (Real)(v.Value);
        }
        private static Optional<List<Byte>> GetOptionalOfBinary(SqlDataReader dr, String FieldName)
        {
            var v = dr.GetSqlBinary(dr.GetOrdinal(FieldName));
            if (v.IsNull) { return Optional<List<Byte>>.Empty; }
            return new List<Byte>(v.Value);
        }
    }

