#Template DataAccessEnum EnumName:String
    private static [[${EnumName}]] [[Get${EnumName}]](SqlDataReader dr, String FieldName)
    {
        return ([[${EnumName}]])(GetInt(dr, FieldName));
    }
    private static Optional<[[${EnumName}]]> [[GetOptionalOf${EnumName}]](SqlDataReader dr, String FieldName)
    {
        var v = GetOptionalOfInt(dr, FieldName);
        if (v.OnNone) { return Optional<[[${EnumName}]]>.Empty; }
        return ([[${EnumName}]])(v.Value);
    }
    private static void Add(SqlCommand cmd, String ParameterName, [[${EnumName}]] Value)
    {
        Add(cmd, ParameterName, (Int)(Value));
    }
    private static void Add(SqlCommand cmd, String ParameterName, Optional<[[${EnumName}]]> Value)
    {
        if (Value.OnNone)
        {
            Add(cmd, ParameterName, Optional<Int>.Empty);
        }
        else
        {
            Add(cmd, ParameterName, (Int)(Value.Value));
        }
    }

